# Copy to /opt/zymtech_innovation/.env on the server and edit secrets.
# PostgreSQL on the same host (local socket or 127.0.0.1).
# Example: create DB and user in psql first.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Local PostgreSQL — replace USER, PASS, DB
DATABASE_URL=postgresql+psycopg2://USER:PASS@127.0.0.1:5432/DBNAME

# Absolute paths recommended in production
UPLOAD_DIR=/opt/zymtech_innovation/data/uploads
RENDER_DIR=/opt/zymtech_innovation/data/renders

FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe

# Browser origin for the public site (HTTPS)
CORS_ORIGINS=https://mixer.wavelync.com

# Uvicorn (optional; systemd overrides bind via ExecStart)
HOST=127.0.0.1
PORT=8000

# Render engine: "local" (FFmpeg) or "shotstack" (cloud).
VIDEO_ENGINE=shotstack

# HTTPS prefix where UPLOAD_DIR is publicly reachable; Shotstack fetches source
# clips over this URL. Must be served by Nginx `location /uploads/` aliasing
# to UPLOAD_DIR.
PUBLIC_UPLOAD_URL_PREFIX=https://mixer.wavelync.com/uploads

# Shotstack — keep exactly one style. Either a single API key, OR sandbox+production
# keys with SHOTSTACK_USE_PRODUCTION toggling between them.
#SHOTSTACK_API_KEY=
SHOTSTACK_SANDBOX_KEY=
SHOTSTACK_PRODUCTION_KEY=
SHOTSTACK_USE_PRODUCTION=true
# Explicit host segment override; auto-derives to v1 (prod) or stage (sandbox).
#SHOTSTACK_API_ENV=v1
