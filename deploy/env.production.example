# Copy to /opt/zymtech_innovation/.env on the server and edit secrets.
# PostgreSQL on the same host (local socket or 127.0.0.1).
# Example: create DB and user in psql first.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Local PostgreSQL — replace USER, PASS, DB
DATABASE_URL=postgresql+psycopg2://USER:PASS@127.0.0.1:5432/DBNAME

# Absolute paths recommended in production
UPLOAD_DIR=/opt/zymtech_innovation/data/uploads
RENDER_DIR=/opt/zymtech_innovation/data/renders

FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe

# Browser origin for the public site (HTTPS)
CORS_ORIGINS=https://mixer.wavelync.com

# Uvicorn (optional; systemd overrides bind via ExecStart)
HOST=127.0.0.1
PORT=8000
