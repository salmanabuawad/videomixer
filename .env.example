# OpenAI: can also be stored in DB table `app_config` (keys: openai_api_key, openai_model).
# Video / Shotstack: same table — keys video_engine, public_upload_url_prefix, shotstack_api_key,
# shotstack_sandbox_key, shotstack_production_key, shotstack_use_production, shotstack_api_env.
# Non-empty DB values override env for those settings.
# Non-empty DB values override these env vars at runtime.
# REQUIRED for extract/render: paste a real sk-... key (do not leave the placeholder).
OPENAI_API_KEY=
# Optional: require this value in the "Admin token" field in Settings UI to save keys after the first setup.
CONFIG_ADMIN_TOKEN=
OPENAI_MODEL=gpt-4o
# PostgreSQL (SQLAlchemy + psycopg2)
DATABASE_URL=postgresql+psycopg2://zymtech:zymtech@localhost:5432/zymtech
# Local SQLite (no Postgres): uncomment and use instead
# DATABASE_URL=sqlite:///./zymtec.db

UPLOAD_DIR=./data/uploads
RENDER_DIR=./data/renders
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
HOST=0.0.0.0
PORT=8000
# Frontend dev server origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Video: local (FFmpeg) or shotstack. When set, overrides app_config `video_engine` (use for systemd deploys).
VIDEO_ENGINE=local
# Shotstack (optional; or configure via Settings → app_config)
# SHOTSTACK_API_KEY=
# SHOTSTACK_SANDBOX_KEY=
# SHOTSTACK_PRODUCTION_KEY=
SHOTSTACK_USE_PRODUCTION=false
# SHOTSTACK_API_ENV=stage
# HTTPS URL where UPLOAD_DIR is publicly served (required for shotstack)
PUBLIC_UPLOAD_URL_PREFIX=
