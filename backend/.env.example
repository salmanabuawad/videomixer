PORT=4010
DATABASE_URL=postgresql://videomixer:CHANGEME@127.0.0.1:5432/videomixer
REDIS_URL=redis://127.0.0.1:6379

# 32+ char random secret used to AES-encrypt the `config` table values
ENCRYPTION_KEY=change_this_to_a_long_random_secret

# Secret used to sign session JWTs
JWT_SECRET=change_this_to_a_long_random_secret

# Python worker (yt-dlp / ffmpeg / evaluate) base URL
WORKER_BASE_URL=http://127.0.0.1:8101

# Comma-separated list of allowed Origins for CORS
FRONTEND_ORIGIN=http://localhost:5173

# Seed-only — used by `npm run seed` to create / update the admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_login
